{
	"name": "gennaker",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:cf": "npm run build && wrangler dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:int": "vitest run --config vitest.int.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply gennaker --local",
		"db:migrate:remote": "wrangler d1 migrations apply gennaker --remote",
		"dev:seed": "tsx scripts/import-export.ts --local",
		"prod:seed": "tsx scripts/import-export.ts --remote"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.14.9",
		"@cloudflare/workers-types": "^4.20260422.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.6.0",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5",
		"wrangler": "^4.84.1"
	},
	"dependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"bcryptjs": "^3.0.3",
		"drizzle-orm": "^0.45.2",
		"fflate": "^0.8.2",
		"marked": "^18.0.2",
		"nanoid": "^5.1.9",
		"zod": "^4.3.6"
	}
}
